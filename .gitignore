# Claude Code (instrucciones locales, no van al repo)
CLAUDE.md

# Entorno Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Notebooks checkpoints
.ipynb_checkpoints/

# Pesos de modelos (grandes, no versionables)
sam3/checkpoints/
sam3/*.pth
sam3/*.pt
*.pth
*.pt

# ── Salidas del pipeline ──────────────────────────────────────────────────────

# Frames extraídos (regenerables con extract_frames.py)
