output/masks/

# Imágenes de debug temporales
output/debug/*_grid.jpg
output/debug/*_candidates.jpg
output/debug/test*.jpg

# Cache de datasets YOLO (regenerable)
output/yolo_dataset/*.cache
output/yolo_dataset/images/train.cache
output/yolo_dataset/images/val.cache

# Resultados de entrenamiento YOLO (artefactos intermedios)
runs/

# Scratch de investigación
github-research-output/

